# Workspace and hoisting settings have moved to pnpm-workspace.yaml.
# As of pnpm 11, these settings are read from pnpm-workspace.yaml
# (camelCase keys), not from .npmrc. See pnpm-workspace.yaml for:
#   linkWorkspacePackages, saveWorkspaceProtocol, includeWorkspaceRoot,
#   sharedWorkspaceLockfile, hoistPattern, shamefullyHoist
