{
  "name": "@eligian/vscode-extension",
  "description": "The extension specific package",
  "version": "0.0.1",
  "displayName": "Eligian",
  "type": "module",
  "publisher": "rolandzwaga",
  "engines": {
    "vscode": "^1.107.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "languages": [
      {
        "id": "eligian",
        "aliases": [
          "Eligian",
          "eligian"
        ],
        "extensions": [
          ".eligian"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "eligian",
        "scopeName": "source.eligian",
        "path": "syntaxes/eligian.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "eligian.compile",
        "title": "Eligian: Compile Current File",
        "category": "Eligian"
      },
      {
        "command": "eligian.preview",
        "title": "Eligian: Preview Timeline",
        "category": "Eligian",
        "icon": "$(preview)"
      },
      {
        "command": "eligian.openLabelEditor",
        "title": "Eligian: Edit Locales",
        "category": "Eligian",
        "icon": "$(edit)"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "when": "resourceLangId == eligian",
          "command": "eligian.compile",
          "group": "eligian"
        },
        {
          "when": "resourceLangId == eligian",
          "command": "eligian.preview",
          "group": "eligian"
        },
        {
          "when": "resourceLangId == eligian",
          "command": "eligian.openLabelEditor",
          "group": "eligian"
        }
      ],
      "commandPalette": [
        {
          "command": "eligian.compile",
          "when": "editorLangId == eligian"
        },
        {
          "command": "eligian.preview",
          "when": "editorLangId == eligian"
        },
        {
          "command": "eligian.openLabelEditor",
          "when": "editorLangId == eligian"
        }
      ]
    },
    "keybindings": [
      {
        "command": "eligian.preview",
        "key": "ctrl+k v",
        "mac": "cmd+k v",
        "when": "editorLangId == eligian"
      }
    ],
    "customEditors": [
      {
        "viewType": "eligian.localeEditor",
        "displayName": "Locale Editor",
        "selector": [
          {
            "filenamePattern": "**/*locale*.json"
          }
        ],
        "priority": "option"
      }
    ]
  },
  "activationEvents": [
    "onLanguage:eligian"
  ],
  "main": "./out/extension/main.cjs",
  "scripts": {
    "clean": "shx rm -fr *.tsbuildinfo out syntaxes",
    "vscode:prepublish": "pnpm run build",
    "build:prepare": "shx mkdir -p ./syntaxes/ && shx cp -f ../language/syntaxes/eligian.tmLanguage.json ./syntaxes/eligian.tmLanguage.json",
    "build": "pnpm run build:prepare && node esbuild.mjs",
    "build:clean": "pnpm run clean && pnpm run build",
    "watch": "pnpm run build:prepare && concurrently -n tsgo,esbuild -c blue,yellow \"tsgo -b tsconfig.json --watch\" \"node esbuild.mjs --watch\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui"
  },
  "dependencies": {
    "@eligian/language": "workspace:*",
    "@eligian/shared-utils": "workspace:*",
    "jquery": "4.0.0",
    "lottie-web": "5.13.0",
    "video.js": "8.23.7",
    "vscode-languageclient": "9.0.1",
    "vscode-languageserver": "10.0.0"
  },
  "devDependencies": {
    "@types/jquery": "4.0.1",
    "@types/vscode": "1.120.0",
    "@vitest/ui": "4.1.8",
    "concurrently": "10.0.3",
    "jsdom": "29.1.1"
  },
  "vsce": {
    "dependencies": false
  }
}
