{
  "name": "@eligian/language",
  "description": "The language specific package",
  "version": "0.0.1",
  "type": "module",
  "engines": {
    "node": ">=20.10.0",
    "npm": ">=10.2.3"
  },
  "files": [
    "dist",
    "out",
    "src"
  ],
  "main": "./dist/index.cjs",
  "types": "./out/index.d.ts",
  "exports": {
    ".": {
      "types": "./out/index.d.ts",
      "default": "./dist/index.cjs"
    },
    "./css-service": {
      "types": "./out/css/css-service.d.ts",
      "default": "./dist/css/css-service.cjs"
    },
    "./errors": {
      "types": "./out/errors/index.d.ts",
      "default": "./dist/errors/index.cjs"
    }
  },
  "typesVersions": {
    "*": {
      ".": [
        "out/index"
      ]
    }
  },
  "scripts": {
    "clean": "shx rm -fr *.tsbuildinfo out dist coverage",
    "generate:metadata": "tsx src/completion/generate-metadata.ts",
    "generate:registry": "tsx src/compiler/operations/generate-registry.ts",
    "generate:html-metadata": "tsx ../../scripts/generate-html-metadata.ts",
    "generate": "pnpm run generate:metadata && pnpm run generate:registry && pnpm run generate:html-metadata && pnpm run langium:generate",
    "build": "pnpm run generate && node esbuild.mjs && tsgo -p tsconfig.src.json --emitDeclarationOnly",
    "build:clean": "pnpm run clean && pnpm run build",
    "langium:generate": "langium generate",
    "langium:watch": "langium generate --watch",
    "test": "vitest run --reporter=dot --hideSkippedTests",
    "test:coverage:ci": "vitest run --coverage"
  },
  "dependencies": {
    "@eligian/shared-utils": "workspace:*",
    "ajv": "8.20.0",
    "htmlparser2": "12.0.0",
    "langium": "4.2.4",
    "postcss": "8.5.15",
    "postcss-selector-parser": "7.1.3",
    "typir": "0.3.3",
    "typir-langium": "0.3.3"
  },
  "devDependencies": {
    "jsdom": "29.1.1",
    "langium-cli": "4.2.1"
  }
}
