{
  "name": "eligian",
  "description": "Base workspace package",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "scripts": {
    "clean": "pnpm -r clean",
    "watch": "tsgo -b tsconfig.build.json --watch",
    "build": "pnpm -r build",
    "build:clean": "pnpm clean && pnpm build",
    "langium:generate": "pnpm --filter @eligian/language langium:generate",
    "langium:watch": "pnpm --filter @eligian/language langium:watch",
    "generate:html-metadata": "tsx scripts/generate-html-metadata.ts",
    "test": "pnpm -r test",
    "test:coverage:ci": "pnpm -r test:coverage:ci",
    "test:coverage": "tsx tools/pruned-coverage.ts",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "ci": "biome ci .",
    "typecheck": "tsgo -b tsconfig.build.json",
    "effect:check": "pnpm effect:check:language && pnpm effect:check:cli",
    "effect:check:language": "effect-language-service diagnostics --project packages/language/tsconfig.src.json --format text",
    "effect:check:cli": "effect-language-service diagnostics --project packages/cli/tsconfig.json --format text"
  },
  "dependencies": {
    "effect": "3.21.3",
    "eligius": "2.2.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@effect/language-service": "^0.86.2",
    "@types/node": "25.9.3",
    "@typescript/native-preview": "7.0.0-dev.20260603.1",
    "@vitest/coverage-v8": "4.1.8",
    "esbuild": "0.28.1",
    "shx": "0.4.0",
    "tsx": "4.22.4",
    "typescript": "^6.0.3",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "4.1.8"
  },
  "packageManager": "pnpm@11.7.0+sha512.19cc852c120c7125760f2443ee6be0ca5b40f9f50598de1a09a1f177503e010e57c23c77646e01e761de59bf874fb22a3398c33ab9691fc13eb946b6f0f4d620"
}
