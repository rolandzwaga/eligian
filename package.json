{
  "name": "eligian",
  "description": "Base workspace package",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "scripts": {
    "clean": "pnpm -r clean",
    "watch": "tsgo -b tsconfig.build.json --watch",
    "build": "pnpm -r build",
    "build:clean": "pnpm clean && pnpm build",
    "langium:generate": "pnpm --filter @eligian/language langium:generate",
    "langium:watch": "pnpm --filter @eligian/language langium:watch",
    "generate:html-metadata": "tsx scripts/generate-html-metadata.ts",
    "test": "pnpm -r test",
    "test:coverage:ci": "pnpm -r test:coverage:ci",
    "test:coverage": "tsx tools/pruned-coverage.ts",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "ci": "biome ci .",
    "typecheck": "tsgo -b tsconfig.build.json",
    "effect:check": "pnpm effect:check:language && pnpm effect:check:cli",
    "effect:check:language": "effect-language-service diagnostics --project packages/language/tsconfig.src.json --format text --strict",
    "effect:check:cli": "effect-language-service diagnostics --project packages/cli/tsconfig.json --format text --strict"
  },
  "dependencies": {
    "effect": "3.21.4",
    "eligius": "2.3.2"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.1",
    "@effect/language-service": "^0.86.2",
    "@types/node": "25.9.3",
    "@typescript/native-preview": "7.0.0-dev.20260603.1",
    "@vitest/coverage-v8": "4.1.9",
    "esbuild": "0.28.1",
    "shx": "0.4.0",
    "tsx": "4.22.4",
    "typescript": "^6.0.3",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "4.1.9"
  },
  "packageManager": "pnpm@11.9.0+sha512.bd682d5d03fe525ef7c9fd6780c6884d1e756ac4c9c9fe00c538782824310dcf90e3ddc4f53835f06dfaebd5085e41855e0bcbb3b60de2ac5bbab89e5036f03b"
}
