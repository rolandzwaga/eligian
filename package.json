{
  "name": "eligian",
  "description": "Base workspace package",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "scripts": {
    "clean": "pnpm -r clean",
    "watch": "tsgo -b tsconfig.build.json --watch",
    "build": "pnpm -r build",
    "build:clean": "pnpm clean && pnpm build",
    "langium:generate": "pnpm --filter @eligian/language langium:generate",
    "langium:watch": "pnpm --filter @eligian/language langium:watch",
    "generate:html-metadata": "tsx scripts/generate-html-metadata.ts",
    "test": "pnpm -r test",
    "test:coverage:ci": "pnpm -r test:coverage:ci",
    "test:coverage": "tsx tools/pruned-coverage.ts",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "ci": "biome ci .",
    "typecheck": "tsgo -b tsconfig.build.json",
    "knip": "knip",
    "knip:fix": "knip --fix"
  },
  "dependencies": {
    "effect": "3.21.2",
    "eligius": "2.2.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.13",
    "@types/node": "25.6.0",
    "@typescript/native-preview": "7.0.0-dev.20260427.1",
    "@vitest/coverage-v8": "4.1.5",
    "esbuild": "0.28.0",
    "shx": "0.4.0",
    "tsx": "4.21.0",
    "typescript": "^6.0.3",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "4.1.5"
  },
  "packageManager": "pnpm@10.33.2+sha512.a90faf6feeab71ad6c6e57f94e0fe1a12f5dcc22cd754db40ae9593eb6a3e0b6b12e3540218bb37ae083404b1f2ce6db2a4121e979829b4aff94b99f49da1cf8"
}
